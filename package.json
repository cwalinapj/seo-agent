{
  "name": "seo-agent",
  "version": "1.0.0",
  "description": "Cloudflare Worker + D1 backend for citation dashboard",
  "main": "index.js",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:prod": "wrangler deploy --env production",
    "db:migrate": "wrangler d1 migrations apply seo_agent --remote",
    "db:migrate:staging": "wrangler d1 migrations apply seo_agent_staging --remote",
    "db:migrate:prod": "wrangler d1 migrations apply seo_agent_prod --remote",
    "db:seed": "wrangler d1 execute seo_agent --remote --file=./seeds_citation_sources.sql",
    "check": "node ./scripts/check.js",
    "test": "node --test tests/*.mjs",
    "browser-checker:install": "npm i playwright",
    "browser-checker:run": "node ./browser-checker/server.mjs",
    "ci": "npm run check && npm run test"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "wrangler": "^4.69.0"
  },
  "dependencies": {
    "playwright": "^1.58.2"
  }
}
